{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "frontend/dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/employees/(.*)", "dest": "api/index.py" },
    { "src": "/employees", "dest": "api/index.py" },
    { "src": "/seats/(.*)", "dest": "api/index.py" },
    { "src": "/seats", "dest": "api/index.py" },
    { "src": "/projects/(.*)", "dest": "api/index.py" },
    { "src": "/projects", "dest": "api/index.py" },
    { "src": "/dashboard/(.*)", "dest": "api/index.py" },
    { "src": "/dashboard", "dest": "api/index.py" },
    { "src": "/ai/(.*)", "dest": "api/index.py" },
    { "src": "/ai", "dest": "api/index.py" },
    { "src": "/docs/?", "dest": "api/index.py" },
    { "src": "/redoc/?", "dest": "api/index.py" },
    { "src": "/openapi.json", "dest": "api/index.py" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(employees|projects|seats|admin)", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
